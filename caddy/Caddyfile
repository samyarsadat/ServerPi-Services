# Global configs
{
    servers {
        metrics
    }

    admin 0.0.0.0:2019
    auto_https off
}

# Logging
(log_common) {
    log {
        output file /data/logs/caddy_access.log {
            roll_size 20mb
            roll_keep 5
        }
    }
}


# Proxy routes
http://two-whoami.{$MY_DOMAIN} {
    import log_common
    reverse_proxy whoami:80
}
